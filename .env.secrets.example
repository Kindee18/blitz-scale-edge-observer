# Blitz-Scale Edge Observer - Secret Template
# Instructions:
# 1. Copy this file to .env.secrets: cp .env.secrets.example .env.secrets
# 2. Populate the values below.
# 3. Run: bash scripts/setup_secrets.sh
# 4. DELETE .env.secrets after use (or ensure it's in .gitignore)

# AWS Role ARN for GitHub Actions OIDC
# Example: arn:aws:iam::123456789012:role/GithubActionsRole
AWS_ROLE_ARN=

# Cloudflare API Token (Edit permissions for Workers)
CF_API_TOKEN=

# (Optional) Webhook Secret for Edge Worker validation
# WEBHOOK_SECRET_TOKEN=
