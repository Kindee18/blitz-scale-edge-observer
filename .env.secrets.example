# Blitz-Scale Edge Observer - Environment Secrets Template
# Copy this file to .env.secrets and fill in your actual values
# DO NOT commit .env.secrets to version control!

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS Region for all resources
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# AWS Credentials (only needed for local development)
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=

# =============================================================================
# EKS / Kubernetes Configuration
# =============================================================================

EKS_CLUSTER_NAME=blitz-edge-cluster
EKS_CLUSTER_VERSION=1.28
KARPENTER_VERSION=v0.32.0

# =============================================================================
# Lambda / Predictive Scaler Configuration
# =============================================================================

DYNAMODB_LOCK_TABLE=blitz-scaling-locks
SCHEDULE_S3_BUCKET=blitz-edge-config-123456789012
SCHEDULE_S3_KEY=game_schedules/nfl_today.json
LEAD_TIME_MINUTES=45
LOCK_TTL_SECONDS=300
DRY_RUN_MODE=false

# =============================================================================
# Kinesis / Delta Processor Configuration
# =============================================================================

KINESIS_STREAM_NAME=blitz-data-stream
KINESIS_SHARD_COUNT=10
STATE_TABLE_NAME=blitz-game-state-versions
REDIS_URL=redis://blitz-redis.abc123.cache.amazonaws.com:6379
REDIS_PASSWORD=

# =============================================================================
# Cloudflare Edge Worker Configuration
# =============================================================================

CF_ACCOUNT_ID=REPLACE_WITH_CF_ACCOUNT_ID
CF_ZONE_ID=REPLACE_WITH_CF_ZONE_ID
CF_API_TOKEN=REPLACE_WITH_CF_API_TOKEN
GAME_STATE_KV_ID=REPLACE_WITH_GAME_STATE_KV_ID

# =============================================================================
# Webhook / Security Configuration
# =============================================================================

WEBHOOK_SECRET_TOKEN=REPLACE_WITH_WEBHOOK_SECRET_TOKEN
JWT_SECRET=REPLACE_WITH_JWT_SECRET

# =============================================================================
# Secrets Manager Paths (AWS)
# =============================================================================

SECRETS_MANAGER_WEBHOOK_PATH=blitz-edge/webhook-token
SECRETS_MANAGER_REDIS_PATH=blitz-edge/redis-password
SECRETS_MANAGER_JWT_PATH=blitz-edge/jwt-secret

# =============================================================================
# Monitoring & Observability
# =============================================================================

CLOUDWATCH_NAMESPACE=BlitzScale/Edge
XRAY_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io:443
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=REPLACE_WITH_OTEL_API_KEY

# =============================================================================
# FantasyPros Integration Settings
# =============================================================================

DEFAULT_SCORING_FORMAT=ppr
MAX_LEAGUES_PER_USER=10
ENABLE_START_SIT_SIGNALS=true

# =============================================================================
# Cost Optimization (FinOps)
# =============================================================================

LOG_RETENTION_DAYS=7
S3_LOG_ARCHIVE_BUCKET=blitz-logs-archive-123456789012
COST_CENTER=fantasypros-platform

# =============================================================================
# Deployment Configuration
# =============================================================================

AWS_ROLE_ARN=arn:aws:iam::123456789012:role/GitHubActions-DeployRole
AWS_ROLE_ARN_STAGING=arn:aws:iam::123456789012:role/GitHubActions-DeployRole-Staging
SLACK_WEBHOOK_URL=REPLACE_WITH_SLACK_WEBHOOK_URL
